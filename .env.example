# =============================================================================
# School Library — environment variables
# Copy this file to .env (or .env.local) and fill in real values for local dev.
# On Railway, set the same names in the service's Variables tab.
# =============================================================================

# --- Database (Railway Postgres plugin auto-populates DATABASE_URL) -----------
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# --- NextAuth (step 2) -------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# In production, set to the Railway-provided URL (e.g. https://your-app.up.railway.app)
NEXTAUTH_URL="http://localhost:3000"

# --- Cloudflare R2 -----------------------------------------------------------
# Get these from the R2 dashboard → Manage R2 API Tokens.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Use the S3-compatible endpoint shown in the R2 dashboard, e.g.
#   https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=""
# How long signed download URLs stay valid (seconds). 5 minutes is plenty for reading.
R2_SIGNED_URL_TTL_SECONDS="300"

# --- Google Gemini (step 7) ---------------------------------------------------
GEMINI_API_KEY=""

# --- Seed bootstrap admin (used by prisma/seed.ts on first deploy) ----------
# Set these BEFORE the first deploy to create the initial ADMIN.
# After the first deploy, you can clear them — the seed is idempotent.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME=""
