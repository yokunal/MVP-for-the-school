// Prisma schema for the school digital library — TEMPORARILY switched to
// SQLite for offline testing of the PDF reader. Postgres schema preserved in
// /tmp/prisma.postgres.bak on this machine.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums were replaced by String columns because SQLite doesn't support
// Prisma's `enum` keyword. The runtime `Library` and `Role` constants +
// matching TypeScript types live in src/types/index.ts.

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  passwordHash        String
  role                String
  classGrade          Int?
  isActive            Boolean  @default(true)
  mustChangePassword  Boolean  @default(true)
  sessionVersion      Int      @default(0)
  createdAt           DateTime @default(now())

  uploadedBooks   Book[]            @relation("UploadedBy")
  readingProgress ReadingProgress[]
}

model Book {
  id            String   @id @default(cuid())
  title         String
  author        String
  synopsis      String
  subject       String
  coverImageKey String?
  pdfKey        String?
  epubKey       String?
  library       String
  uploadedById  String
  uploadedBy    User     @relation("UploadedBy", fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())
  deletedAt     DateTime?

  readingProgress ReadingProgress[]

  @@index([library])
  @@index([title])
  @@index([author])
}

model ReadingProgress {
  id           String   @id @default(cuid())
  userId       String
  bookId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  lastLocation String
  updatedAt    DateTime @updatedAt

  @@unique([userId, bookId])
  @@index([userId])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorId       String
  actorEmail    String
  action        String
  targetUserId  String?
  targetBookId  String?
  metadata      String?  // JSON string — SQLite has no native JSON column
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([actorId])
}
